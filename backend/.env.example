# Server
PORT=5000
NODE_ENV=production

# Frontend URL (para CORS)
FRONTEND_URL=https://seu-dominio.com.br

# Database
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/DBNAME

# JWT
JWT_SECRET=your-jwt-secret-here-use-strong-key
JWT_EXPIRE=7d

# Stripe (Pagamentos)
STRIPE_PUBLIC_KEY=pk_live_xxxxx
STRIPE_SECRET_KEY=sk_live_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Melhor Envio (Entrega)
MELHOR_ENVIO_API_KEY=seu-token-jwt-melhor-envio
MELHOR_ENVIO_BASE_URL=https://api.melhorenvio.com.br/api/v2
CEP_ORIGEM=00000000

# Cloudinary (para upload de imagens)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# SendGrid (Email)
SENDGRID_API_KEY=SG.xxxxx
SENDGRID_FROM_EMAIL=seu-email@dominio.com.br
SENDGRID_FROM_NAME=Nome da Loja
SENDGRID_FROM_EMAIL_CONTACT=seu-email@dominio.com.br
SENDGRID_FROM_EMAIL_NOTIFICATIONS=seu-email@dominio.com.br
CONTACT_RECEIVER_EMAIL=seu-email@dominio.com.br
